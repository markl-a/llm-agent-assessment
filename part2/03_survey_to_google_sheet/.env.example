# ============================================================================
# 環境變數範本 —— 複製為 .env 後填入你自己的值。
# 切勿把真實金鑰、憑證檔內容或 .env 提交進版本庫（請把 .env 與 *.json 加入 .gitignore）。
# ============================================================================

# ---- LLM（選擇題答案解析，走 part2/common 共用抽象層，OpenAI 相容）----------------
# 預設供應商為 Groq，模型 llama-3.3-70b-versatile。run_demo.py 只需要下面這一把金鑰。
# 取得方式：https://console.groq.com/keys
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# （選用）切換 LLM 供應商 / 模型。留空則用預設 Groq。
#   可選 provider：groq | openrouter | cerebras | together | nvidia | mistral
# LLM_PROVIDER=groq
# LLM_MODEL=llama-3.3-70b-versatile

# ---- Embedding（本專案未使用；共用層預設走 Mistral，若其他專案需要才填）------------
# MISTRAL_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# EMBED_PROVIDER=mistral
# EMBED_MODEL=mistral-embed

# ---- Google Sheets（選用）--------------------------------------------------------
# 若未設定下面兩項（或找不到憑證檔），資料 sink 會自動降級為寫本地 CSV：responses_local.csv。
# 有憑證時才會走 gspread 寫入 Google Sheet。
#
# Google Cloud service account 的 JSON 金鑰「檔案路徑」（不是 JSON 內容本身）。
# 例：/home/you/secrets/service_account.json 或 C:\\Users\\you\\secrets\\service_account.json
# GOOGLE_SERVICE_ACCOUNT_FILE=/absolute/path/to/service_account.json

# 目標試算表 ID：試算表網址中 /d/ 與 /edit 之間那一段。
# 例：https://docs.google.com/spreadsheets/d/1AbCdEfGhIjKlMnOpQrStUvWxYz/edit → 1AbCdEfGhIjKlMnOpQrStUvWxYz
# SPREADSHEET_ID=1AbCdEfGhIjKlMnOpQrStUvWxYz
