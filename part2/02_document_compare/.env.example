# 複製本檔為 .env 後填入實際值。切勿把真實金鑰寫進版本控制。
# 所有敏感值一律走環境變數 / .env。

# === API 金鑰（由 part2/common/ 依供應商讀取）===
GROQ_API_KEY=請填入你的-Groq-金鑰          # LLM（預設 Groq llama-3.3-70b-versatile）
MISTRAL_API_KEY=請填入你的-Mistral-金鑰    # Embedding（預設 mistral-embed，1024 維）
# 缺 MISTRAL_API_KEY 時，嵌入會自動退回離線 hash（非語意）以維持可執行（會警示）。

# === 供應商 / 模型切換（皆可留空用預設；由 common 抽象層解讀）===
# LLM_PROVIDER=groq        # groq | openrouter | cerebras | together | nvidia | mistral
# LLM_MODEL=llama-3.3-70b-versatile
# EMBED_PROVIDER=mistral   # mistral | nvidia | together | openai
# EMBED_MODEL=mistral-embed

# === 嵌入後端：api（預設，走 common.embed_texts）/ hash（離線非語意，僅供結構性測試）===
EMBEDDING_BACKEND=api
HASH_EMBED_DIM=512

# === 切塊參數（僅粗估；範例合約很短，run_demo 會用較小的預設）===
TARGET_CHARS=1600
OVERLAP_CHARS=200
MAX_CHUNK_CHARS=8000

# === 對齊參數 ===
ALIGN_THRESHOLD=0.72
ALIGN_BLOCK=1024
ALIGN_TOPK=10
# 上千頁以上、且已 `pip install faiss-cpu` 時，設 1 走 top-k 向量檢索
USE_FAISS=0

# === map / reduce 併發與 token 預算 ===
MAP_CONCURRENCY=6
REDUCE_CONCURRENCY=3
MAP_MAX_TOKENS=1024
REDUCE_MAX_TOKENS=2048
REDUCE_TOKEN_BUDGET=24000
REPORT_MAX_TOKENS_CAP=3000

# === 速率限制（token-bucket，TPM/RPM；預設貼近 Groq 免費層，請依帳號調整）===
LLM_RPM=28
LLM_TPM=12000

# === Checkpoint 目錄（中斷可續跑）===
CHECKPOINT_DIR=.doccompare_checkpoints
