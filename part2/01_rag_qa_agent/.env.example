# ------------------------------------------------------------------
# 環境變數範本：複製為 .env 後填入你的金鑰。
#   cp .env.example .env
# .env 內含機密，請務必加入 .gitignore，切勿提交進版控。
# 本檔為「範本」，不得填入真實金鑰。
# ------------------------------------------------------------------
# 本專案 LLM / Embedding 皆走共用 provider 層（part2/common）的 OpenAI 相容端點。
# 預設：LLM=Groq（llama-3.3-70b-versatile）、Embedding=Mistral（mistral-embed）。

# LLM 金鑰（必填）：Groq。至 https://console.groq.com 取得。
GROQ_API_KEY=gsk_your-groq-key-here

# Embedding 金鑰（必填）：Mistral。至 https://console.mistral.ai 取得。
MISTRAL_API_KEY=your-mistral-key-here

# （選用）覆寫供應商 / 模型；不設定則用上述預設。
# LLM_PROVIDER=groq
# LLM_MODEL=llama-3.3-70b-versatile
# EMBED_PROVIDER=mistral
# EMBED_MODEL=mistral-embed
