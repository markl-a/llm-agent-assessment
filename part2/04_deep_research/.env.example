# 複製為 .env 後填入真實值；切勿把真實金鑰提交進版本庫。
# LLM / Embedding 皆走共用 provider 抽象層（part2/common），OpenAI 相容。

# ---- LLM（規劃/搜尋/閱讀/驗證/彙整）------------------------------------
# 供應商可選：groq | openrouter | cerebras | together | nvidia | mistral（預設 groq）
LLM_PROVIDER=groq
# 可選：覆寫預設模型（groq 預設 llama-3.3-70b-versatile）
# LLM_MODEL=llama-3.3-70b-versatile
# 對應金鑰（依 LLM_PROVIDER 擇一設定；預設 groq → GROQ_API_KEY）
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ---- Embedding（搜尋結果的輕量向量 rerank）-----------------------------
# 供應商可選：mistral | nvidia | together | openai（預設 mistral）
EMBED_PROVIDER=mistral
# EMBED_MODEL=mistral-embed
# 缺此金鑰時，向量 rerank 會自動略過（不影響主流程）。
MISTRAL_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ---- 搜尋 --------------------------------------------------------------
# 預設 DuckDuckGo（免金鑰），無需任何 KEY。
# 要改接其他搜尋供應商（Tavily/Bing/SerpAPI…），實作
# deep_research.search.SearchProvider.search(query, max_results) 即可，不需改動其他程式。
